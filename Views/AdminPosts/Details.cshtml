@model WebMkt.Models.Post

@{
    ViewData["Title"] = "Chi tiết bài viết";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-9">
        <div class="mb-3 d-flex justify-content-between align-items-center">
            <h3>@Model.Title</h3>
            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <strong>Chuyên mục:</strong> @Model.Category?.Name | 
                <strong>Ngày tạo:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm") | 
                <strong>Trạng thái:</strong> @(Model.IsPublished ? "Đã đăng" : "Nháp")
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                {
                    <div class="mb-4 text-center bg-light p-3 rounded">
                        <img src="@Model.ThumbnailUrl" class="img-fluid rounded shadow-sm" alt="Thumbnail" style="max-height: 400px;" />
                    </div>
                }
                
                <div class="mb-4">
                    @Html.Raw(Model.Content)
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-info text-white">
                <strong>Thông số Meta SEO</strong>
            </div>
            <div class="card-body">
                <p><strong>Slug:</strong> /@Model.Slug</p>
                <p><strong>Meta Title:</strong> @Model.MetaTitle</p>
                <p><strong>Meta Keywords:</strong> @Model.MetaKeywords</p>
                <p><strong>Meta Description:</strong> @Model.MetaDescription</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.SchemaMarkup))
        {
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <strong>Schema Markup</strong>
                </div>
                <div class="card-body">
                    <pre><code class="language-json">@Model.SchemaMarkup</code></pre>
                </div>
            </div>
        }
    </div>
</div>
