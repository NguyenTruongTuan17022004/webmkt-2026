@model IEnumerable<WebMkt.Models.Post>

@{
    ViewData["Title"] = "Danh sách Bài viết";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <div>
        <a asp-action="BulkCreateWithAi" class="btn btn-warning fw-bold text-dark me-2"><i class="bi bi-stack"></i> Viết Bài Hàng Loạt</a>
        <a asp-action="CreateWithAi" class="btn btn-primary"><i class="bi bi-magic"></i> Tạo bài viết 1-1</a>
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Hình ảnh</th>
            <th>Tiêu đề</th>
            <th>Chuyên mục</th>
            <th>URL (Slug)</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-center">Chưa có bài viết nào.</td>
            </tr>
        }
        @foreach (var item in Model)
        {
            <tr>
                <td style="width: 100px;">
                    @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                    {
                        <img src="@item.ThumbnailUrl" alt="Thumbnail" class="img-thumbnail" style="max-height: 60px;" />
                    }
                    else
                    {
                        <span class="text-muted small">Chưa có</span>
                    }
                </td>
                <td>@item.Title</td>
                <td>@(item.Category?.Name ?? "N/A")</td>
                <td>@item.Slug</td>
                <td>
                    @(item.IsPublished ? Html.Raw("<span class='badge bg-success'>Đã xuất bản</span>") : Html.Raw("<span class='badge bg-secondary'>Bản nháp</span>"))
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white"><i class="bi bi-eye"></i> Xem</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary"><i class="bi bi-pencil"></i> Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
