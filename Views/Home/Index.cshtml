@model IEnumerable<WebMkt.Models.Post>

@{
    ViewData["Title"] = "Blog Marketing AI";
    ViewData["Description"] = "Khám phá các bài viết chuẩn SEO được tạo bằng AI và tối ưu hành vi người đọc ngay trên WebMkt.";
}

<section class="hero-section py-5 mb-5">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-7 text-white">
                <span class="badge bg-info text-dark mb-3">AI Content Studio</span>
                <h1 class="display-5 fw-bold mb-3">Tạo nội dung marketing chuẩn SEO bằng AI</h1>
                <p class="lead lh-lg">Tăng tốc chiến dịch content với bài viết độc đáo, thân thiện người dùng và tối ưu cho tìm kiếm. Dễ dàng chỉnh sửa, xuất bản và chia sẻ ngay.</p>
                <div class="mt-4">
                    <a class="btn btn-light btn-lg me-2" asp-controller="AdminPosts" asp-action="CreateWithAi">Bắt đầu viết bài</a>
                    <a class="btn btn-outline-light btn-lg" asp-controller="Home" asp-action="Index">Xem bài mới nhất</a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block">
                <div class="hero-card p-4 rounded-4 shadow-lg bg-white text-dark">
                    <h2 class="h5 mb-3">Bảng tin AI</h2>
                    <p class="text-muted">Tự động sinh dàn ý, chỉnh sửa nội dung, và phân tích SEO bằng một lần nhấp.</p>
                    <div class="d-flex gap-3 flex-column">
                        <div class="feature-box p-3 border rounded">
                            <strong>✅ Chuẩn SEO</strong>
                            <p class="mb-0 text-muted">Tiêu đề, meta, schema tự động tăng khả năng tìm kiếm.</p>
                        </div>
                        <div class="feature-box p-3 border rounded">
                            <strong>✅ Viết từ đối thủ</strong>
                            <p class="mb-0 text-muted">Scrape URL đối thủ, rewrite và tạo bài bản quyền.</p>
                        </div>
                        <div class="feature-box p-3 border rounded">
                            <strong>✅ Giao diện nhanh</strong>
                            <p class="mb-0 text-muted">Thiết kế hiện đại, mobile-friendly và dễ dùng.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="about-section py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h2 class="h1 mb-4">Tại sao chọn WebMkt?</h2>
                <p class="lead mb-4">WebMkt là nền tảng AI tiên tiến giúp doanh nghiệp tạo nội dung marketing chất lượng cao với tốc độ vượt trội.</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <div class="me-3">
                                <i class="bi bi-lightning-charge-fill text-warning fs-4"></i>
                            </div>
                            <div>
                                <h5 class="mb-1">Tốc độ siêu nhanh</h5>
                                <p class="text-muted small">Tạo bài viết hoàn chỉnh chỉ trong vài phút với công nghệ AI tiên tiến.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <div class="me-3">
                                <i class="bi bi-search text-primary fs-4"></i>
                            </div>
                            <div>
                                <h5 class="mb-1">Chuẩn SEO</h5>
                                <p class="text-muted small">Tự động tối ưu meta tags, schema markup và cấu trúc nội dung.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <div class="me-3">
                                <i class="bi bi-shield-check text-success fs-4"></i>
                            </div>
                            <div>
                                <h5 class="mb-1">Nội dung bản quyền</h5>
                                <p class="text-muted small">Công nghệ rewrite thông minh tạo nội dung độc đáo 100%.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start">
                            <div class="me-3">
                                <i class="bi bi-graph-up text-info fs-4"></i>
                            </div>
                            <div>
                                <h5 class="mb-1">Tăng hiệu quả marketing</h5>
                                <p class="text-muted small">Nội dung chất lượng cao giúp cải thiện tỷ lệ chuyển đổi.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="stats-card p-4 rounded-4 shadow-sm bg-white">
                    <h3 class="h4 mb-4 text-center">Thành tựu nổi bật</h3>
                    <div class="row text-center">
                        <div class="col-6 mb-3">
                            <div class="stat-number display-6 fw-bold text-primary">10K+</div>
                            <div class="stat-label text-muted">Bài viết đã tạo</div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="stat-number display-6 fw-bold text-success">500+</div>
                            <div class="stat-label text-muted">Khách hàng hài lòng</div>
                        </div>
                        <div class="col-6">
                            <div class="stat-number display-6 fw-bold text-warning">99%</div>
                            <div class="stat-label text-muted">Độ chính xác AI</div>
                        </div>
                        <div class="col-6">
                            <div class="stat-number display-6 fw-bold text-info">24/7</div>
                            <div class="stat-label text-muted">Hỗ trợ kỹ thuật</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container mb-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="info-card p-4 rounded-4 shadow-sm h-100">
                <h3>Viết nhanh</h3>
                <p class="text-muted">Sinh bài ngay từ từ khóa hoặc URL đối thủ, giữ chất lượng và tối ưu hoá thẻ meta.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="info-card p-4 rounded-4 shadow-sm h-100">
                <h3>Chuẩn SEO</h3>
                <p class="text-muted">Nội dung được xuất ra với cấu trúc HTML sạch và metadata phù hợp cho Google.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="info-card p-4 rounded-4 shadow-sm h-100">
                <h3>Tối ưu chuyển đổi</h3>
                <p class="text-muted">Đính kèm lead magnet và CTA để thu email, tăng hiệu quả marketing.</p>
            </div>
        </div>
    </div>
</section>

<section class="container">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <span class="text-uppercase text-secondary">Mới nhất</span>
            <h2 class="h3 mb-1">Bài viết nổi bật</h2>
            <p class="text-muted mb-0">Xem các bài viết cập nhật gần đây nhất từ hệ thống.</p>
        </div>
        <a class="text-decoration-none" asp-controller="Home" asp-action="Index">Xem tất cả bài viết →</a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var post in Model)
        {
            var excerpt = post.Description;
            if (string.IsNullOrWhiteSpace(excerpt))
            {
                excerpt = System.Text.RegularExpressions.Regex.Replace(post.Content ?? string.Empty, "<.*?>", string.Empty);
                if (excerpt.Length > 170) excerpt = excerpt[..170] + "...";
            }
            <div class="col">
                <article class="post-card h-100 rounded-4 overflow-hidden shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(post.ThumbnailUrl))
                    {
                        <img src="@post.ThumbnailUrl" class="post-card-img" alt="@post.Title" />
                    }
                    <div class="post-card-body p-4 d-flex flex-column">
                        <div class="mb-2 text-uppercase text-info fw-semibold small">@post.Category?.Name</div>
                        <h3 class="h5 mb-3">@post.Title</h3>
                        <p class="text-muted mb-4">@excerpt</p>
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <span class="text-muted small">@post.CreatedAt.ToString("dd/MM/yyyy")</span>
                            <a asp-controller="Home" asp-action="Post" asp-route-slug="@post.Slug" class="btn btn-sm btn-primary">Đọc ngay</a>
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
</section>
